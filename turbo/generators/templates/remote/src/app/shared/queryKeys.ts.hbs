import { createScopedQueryKeys } from '@/shared-util';

/**
 * 이 앱 전용 query key 팩토리 — 모든 키에 `<앱 폴더명>:` 스코프가 자동 접두된다
 * (__APP_NAME__은 rsbuild define으로 빌드 시 앱 폴더명이 주입됨).
 *
 * 앱 안에서는 @lukemorales/query-key-factory의 createQueryKeys를 직접 쓰지 말고
 * 반드시 이것을 사용할 것 — ESLint(no-restricted-imports)로 강제된다.
 */
export const createAppQueryKeys = createScopedQueryKeys(__APP_NAME__);
