import { memo } from 'react';
import { Tag } from 'antd';
import type { AgentRow, Threshold } from '../types';
import { alarmLevel, statusMeta } from '../statusMap';
import {
  answerRatePct,
  formatDuration,
  liveDurationSec,
  toNum,
  toStr,
  totalHandled,
} from '../helpers';

/**
 * 중밀도 행 — 한 줄에 핵심만. Antd Tag + Tailwind 기본 스케일.
 *
 *  [Tag 통화IB]  김민서  3001  5:23  010-3412-...  VIP 상담   응대 31   96%
 */
export interface AgentRowItemProps {
  row: AgentRow;
  nowMs: number;
  thresholds?: Record<string, Threshold>;
  onActivate?: (row: AgentRow) => void;
}

const TAG_COLOR_BY_GROUP: Record<string, string> = {
  available: 'green',
  talking: 'blue',
  ringing: 'orange',
  wrapup: 'purple',
  offline: 'default',
};

const TIME_COLOR_BY_GROUP: Record<string, string> = {
  available: 'text-green-600',
  talking: 'text-blue-600',
  ringing: 'text-orange-600',
  wrapup: 'text-purple-600',
  offline: 'text-gray-400',
};

function AgentRowItemImpl({ row, nowMs, thresholds, onActivate }: AgentRowItemProps) {
  const meta = statusMeta(row.AGENT_STATUS, row.REASON_CODE);
  const dur = liveDurationSec(row, nowMs);
  const alarm = alarmLevel(row.AGENT_STATUS, row.REASON_CODE, dur, thresholds);
  const isAlert = alarm === 2;
  const isWarn = alarm === 1;

  const tagColor = isAlert ? 'red' : isWarn ? 'orange' : TAG_COLOR_BY_GROUP[meta.group];
  const timeClass = isAlert ? 'text-red-600' : isWarn ? 'text-orange-600' : TIME_COLOR_BY_GROUP[meta.group];

  const name = toStr(row.AGENT_NAME) || toStr(row.AGENT_LOGIN_ID) || '?';
  const dn = toStr(row.LOGIN_DN_NO);
  const handled = totalHandled(row);
  const rate = answerRatePct(row);
  const queue = toStr(row.LAST_ICQ_NAME);
  const ani = toStr(row.FINAL_TALK_ANI);
  const currCalls = toNum(row.CURR_MEDIA_CALL_CNT) ?? 0;

  const rowCls = [
    'group grid w-full grid-cols-[80px_minmax(0,1.4fr)_70px_60px_minmax(0,1.4fr)_minmax(0,1.2fr)_70px_50px] items-center gap-3 rounded-md border px-3 py-2 text-left outline-none transition-colors',
    'hover:bg-gray-50 focus-visible:ring-2 focus-visible:ring-blue-500',
    isAlert ? 'border-red-500 bg-red-50/30' : isWarn ? 'border-orange-400' : 'border-gray-200',
  ].join(' ');

  const rateColor = rate == null
    ? 'text-gray-400'
    : rate >= 95 ? 'text-green-600'
    : rate < 75 ? 'text-red-600'
    : 'text-gray-900';

  return (
    <button type="button" onClick={() => onActivate?.(row)} className={rowCls} title={`${name} · ${meta.label} ${formatDuration(dur)}`}>
      <Tag color={tagColor} className="!mr-0 justify-self-start">
        {meta.label}
      </Tag>

      <div className="flex items-center gap-2 min-w-0">
        <span className="truncate text-sm font-medium text-gray-900">{name}</span>
        {currCalls > 1 && (
          <span className="inline-flex h-4 min-w-[16px] items-center justify-center rounded-full bg-blue-100 px-1 font-mono text-[10px] font-bold text-blue-700 tabular-nums">
            ×{currCalls}
          </span>
        )}
      </div>

      <span className="font-mono text-xs text-gray-400 tabular-nums">{dn || '—'}</span>

      <span className={`font-mono text-sm font-semibold tabular-nums ${timeClass}`}>
        {formatDuration(dur)}
      </span>

      <span className="font-mono text-xs text-gray-500 truncate tabular-nums">
        {formatAni(ani) || '—'}
      </span>

      <span className="text-xs text-gray-500 truncate">{queue || '—'}</span>

      <span className="text-xs text-gray-500 text-right">
        응대 <span className="font-mono font-semibold text-gray-900 tabular-nums">{handled || '—'}</span>
      </span>

      <span className={`text-right font-mono text-sm font-semibold tabular-nums ${rateColor}`}>
        {rate != null ? `${rate}%` : '—'}
      </span>
    </button>
  );
}

function formatAni(ani: string): string {
  if (!ani) return '';
  const digits = ani.replace(/[^\d]/g, '');
  if (digits.length === 11 && digits.startsWith('01')) return `${digits.slice(0, 3)}-${digits.slice(3, 7)}-${digits.slice(7)}`;
  return ani;
}

export default memo(AgentRowItemImpl);
