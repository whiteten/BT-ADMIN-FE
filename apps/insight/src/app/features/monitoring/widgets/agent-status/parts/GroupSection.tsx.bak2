import { useMemo, useState } from 'react';
import { Tooltip } from 'antd';
import { ChevronDown } from 'lucide-react';
import type { AgentRow, Density, StatusGroup, Threshold } from '../types';
import { statusMeta } from '../statusMap';
import { type AgentGroup, answerRatePct, totalHandled } from '../helpers';
import AgentCard from './AgentCard';
import AgentDot from './AgentDot';
import AgentRowItem from './AgentRowItem';

/**
 * 그룹 섹션 — 큐/상태/카테고리 단위로 묶은 카드 컨테이너.
 *
 * 헤더 1행 (Tailwind 기본 스케일, 인사이트 앱 컨벤션):
 *   ▾ VIP 상담  SKILL_3001   8명  [분포바]   ·   응대율 94%   처리 248
 */
export interface GroupSectionProps {
  group: AgentGroup;
  density: Density;
  nowMs: number;
  thresholds?: Record<string, Threshold>;
  onActivate?: (row: AgentRow) => void;
  showHeader: boolean;
}

const DIST_BG_BY_GROUP: Record<StatusGroup, string> = {
  talking: 'bg-blue-500',
  available: 'bg-green-500',
  ringing: 'bg-orange-500',
  wrapup: 'bg-purple-500',
  offline: 'bg-gray-300',
};

export default function GroupSection({ group, density, nowMs, thresholds, onActivate, showHeader }: GroupSectionProps) {
  const [collapsed, setCollapsed] = useState(false);

  const dist = useMemo(() => statusDistribution(group.rows), [group.rows]);
  const kpi = useMemo(() => groupKpi(group.rows), [group.rows]);

  const containerCls =
    density === 'card'
      ? 'grid gap-2 grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 2xl:grid-cols-6'
      : density === 'row'
        ? 'flex flex-col gap-1.5'
        : 'grid gap-1 grid-cols-[repeat(auto-fill,minmax(22px,1fr))]';

  const rateColor = kpi.avgRate == null
    ? 'text-gray-400'
    : kpi.avgRate >= 95 ? 'text-green-600'
    : kpi.avgRate < 75 ? 'text-red-600'
    : 'text-gray-900';

  return (
    <section className="space-y-2">
      {showHeader && (
        <header className="flex flex-wrap items-center gap-3 border-b border-gray-200 pb-2">
          <button
            type="button"
            onClick={() => setCollapsed((c) => !c)}
            aria-expanded={!collapsed}
            className="flex items-center gap-1.5 text-sm font-semibold text-gray-900 hover:text-blue-600"
          >
            <ChevronDown className={`h-3.5 w-3.5 transition-transform ${collapsed ? '-rotate-90' : ''}`} />
            <span>{group.label}</span>
          </button>

          {group.sub && (
            <span className="font-mono text-xs text-gray-400">{group.sub}</span>
          )}

          <span className="rounded bg-gray-100 px-1.5 py-0.5 font-mono text-xs font-medium text-gray-600 tabular-nums">
            {group.rows.length}명
          </span>

          {/* 상태 분포 미니바 */}
          <Tooltip
            title={
              <div className="space-y-0.5 text-xs">
                <div>통화 {dist.talking}</div>
                <div>가용 {dist.available}</div>
                <div>호출 {dist.ringing}</div>
                <div>후처리·이석 {dist.wrapup}</div>
                <div>오프라인 {dist.offline}</div>
              </div>
            }
            placement="top"
          >
            <div className="flex h-2 w-28 overflow-hidden rounded-full border border-gray-200">
              {(['talking', 'available', 'ringing', 'wrapup', 'offline'] as StatusGroup[]).map((g) => {
                const n = dist[g];
                if (!n) return null;
                const w = (n / group.rows.length) * 100;
                return <span key={g} className={DIST_BG_BY_GROUP[g]} style={{ width: `${w}%` }} />;
              })}
            </div>
          </Tooltip>

          <div className="ml-auto flex items-center gap-3 text-xs text-gray-500">
            {kpi.avgRate != null && (
              <span>
                응대율 <span className={`font-mono font-semibold tabular-nums ${rateColor}`}>{kpi.avgRate}%</span>
              </span>
            )}
            {kpi.totalHandled > 0 && (
              <span>
                처리 <span className="font-mono font-semibold text-gray-900 tabular-nums">{kpi.totalHandled.toLocaleString()}</span>
              </span>
            )}
          </div>
        </header>
      )}

      {!collapsed && (
        <div className={containerCls}>
          {density === 'card' && group.rows.map((r, i) => (
            <AgentCard key={`${group.id}_${rowKey(r, i)}`} row={r} nowMs={nowMs} thresholds={thresholds} onActivate={onActivate} />
          ))}
          {density === 'row' && group.rows.map((r, i) => (
            <AgentRowItem key={`${group.id}_${rowKey(r, i)}`} row={r} nowMs={nowMs} thresholds={thresholds} onActivate={onActivate} />
          ))}
          {density === 'dot' && group.rows.map((r, i) => (
            <AgentDot key={`${group.id}_${rowKey(r, i)}`} row={r} nowMs={nowMs} thresholds={thresholds} onActivate={onActivate} />
          ))}
        </div>
      )}
    </section>
  );
}

function statusDistribution(rows: AgentRow[]): Record<StatusGroup, number> {
  const d: Record<StatusGroup, number> = { available: 0, talking: 0, ringing: 0, wrapup: 0, offline: 0 };
  for (const r of rows) d[statusMeta(r.AGENT_STATUS, r.REASON_CODE).group]++;
  return d;
}

interface GroupKpi { avgRate: number | null; totalHandled: number }
function groupKpi(rows: AgentRow[]): GroupKpi {
  let rateSum = 0, rateCount = 0, totalHandledSum = 0;
  for (const r of rows) {
    const rate = answerRatePct(r);
    if (rate != null) { rateSum += rate; rateCount++; }
    totalHandledSum += totalHandled(r);
  }
  return {
    avgRate: rateCount > 0 ? Math.round(rateSum / rateCount) : null,
    totalHandled: totalHandledSum,
  };
}

function rowKey(r: AgentRow, idx: number): string {
  const id = r.AGENT_ID ?? r.AGENT_LOGIN_ID ?? r.LOGIN_DN_NO;
  return id != null && id !== '' ? `a_${id}` : `i_${idx}`;
}
