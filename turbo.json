{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "stream",
  "globalDependencies": ["libs/**", "tools/**", "types/**", "tsconfig.base.json", "postcss.config.mjs"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"],
      "env": ["PUBLIC_REACT_QUERY_DEVTOOLS"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["SERVE_OPEN", "SERVE_NO_OPEN", "MF_REMOTE_HOST", "PUBLIC_REACT_QUERY_DEVTOOLS", "NODE_OPTIONS"]
    }
  }
}
