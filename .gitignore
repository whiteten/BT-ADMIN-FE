# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

# 현장 커스텀(custom remote) 산출물 — 현장에서 자체 형상관리.
# 본사 repo는 빌드 껍데기와 빈 등록 파일(module-federation.config.ts·site-manifest.ts)만 유지
apps/custom/src/app/overrides/*
!apps/custom/src/app/overrides/.gitkeep

# host 개발 서버 개인 proxy override (공유본은 proxy.config.js)
apps/host/proxy.config.local.json

# serve-host 스크립트 개인 옵션 override (env 등)
scripts/serve-host.local.json

# build-selective 스크립트 개인 옵션 override (env 등)
scripts/build-selective.local.json

# generate-manual 스킬 개인 설정(로그인 계정) 및 산출 임시 파일
.claude/skills/generate-manual/manual.config.json
.claude/skills/generate-manual/_routes.json
doc/manuals/.manual-progress.json

.nx/cache
.nx/workspace-data
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Claude
# CLAUDE.md
CLAUDE.local.md
.claude/settings.local.json
tmpclaude-*

# taskboard 담당자 개인 작업 문서 — 로컬 전용(저장소 추적 제외)
apps/taskboard/CHANGELOG.md
apps/taskboard/CLAUDE.md
apps/taskboard/PROMPT_LOG.md
apps/taskboard/WORK_STATUS.md

# Cursor — agents.mdc(공유 포인터 룰)만 추적하고 나머지는 무시
.cursor/*
!.cursor/rules/
.cursor/rules/*
!.cursor/rules/agents.mdc
.cursorrules

# Playwright
e2e/screenshots/
e2e/test-results/
e2e/playwright-report/

# OMC
.omc/

# design-sync (claude.ai/design 동기화) — 생성물·스테이징은 무시, durable 입력만 추적
.ds-sync/
ds-bundle/
.design-sync/.cache/
.design-sync/learnings/
.design-sync/node_modules

# turborepo
.turbo

# 개인 로컬 설정 (커밋 금지)
proxy.config.local.json
serve-host.local.json
